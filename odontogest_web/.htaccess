Options -Indexes
RewriteEngine On

# Redirigir todo a index.php excepto archivos/carpetas existentes
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]

# Bloquear acceso a carpetas sensibles
RewriteRule ^(Config|Models|Controllers|Entity)/ - [F,L]
